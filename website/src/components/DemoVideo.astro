<section class="bg-[#f6faf7] border-y border-[#e3ede7] py-16 md:py-24 px-6">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-10 md:mb-12">
      <p class="text-xs uppercase tracking-widest text-[#16a34a] font-bold mb-3">See it in action</p>
      <h2 class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight mb-3">
        From cold clone to a full audit in <span class="text-[#16a34a]">30 seconds</span>.
      </h2>
      <p class="text-gray-500 max-w-2xl mx-auto leading-relaxed">
        Run the audit locally with Claude. Browse results in a dashboard. Ask follow-ups inline when a check fails — and let Claude fix it.
      </p>
    </div>

    <div class="relative rounded-2xl overflow-hidden border border-[#e3ede7] shadow-[0_10px_40px_rgba(5,46,22,0.08)] bg-white">
      <video
        id="demo-video"
        class="block w-full h-auto aspect-video"
        src="/videos/demo.mp4"
        poster="/videos/demo-poster.jpg"
        muted
        playsinline
        webkit-playsinline
        disableRemotePlayback
        disablePictureInPicture
        preload="auto"
        aria-label="CTO Checklist demo — running an audit and asking Claude to fix a failing check"
      ></video>

      <button
        id="demo-replay"
        type="button"
        class="absolute inset-0 hidden items-center justify-center bg-black/30 backdrop-blur-sm transition-opacity cursor-pointer"
        aria-label="Replay demo video"
      >
        <span class="inline-flex items-center gap-2.5 rounded-full bg-[#052e16] text-[#ecfdf5] px-6 py-3 font-bold text-sm shadow-[0_8px_24px_rgba(5,46,22,0.4)]">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M4 9a9 9 0 0114.5-4.5L20 9M20 15a9 9 0 01-14.5 4.5L4 15" />
          </svg>
          Replay
        </span>
      </button>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('demo-video') as HTMLVideoElement | null;
  const replay = document.getElementById('demo-replay') as HTMLButtonElement | null;

  if (video) {
    // Defensive: some iOS configurations require muted to be set as a JS
    // property, not just the HTML attribute, for inline autoplay to work.
    video.muted = true;
    (video as HTMLVideoElement & { playsInline?: boolean }).playsInline = true;

    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    if (!isMobile) {
      // Desktop gets native controls; mobile plays clean + tap to fullscreen.
      video.setAttribute('controls', '');
    } else {
      const onTapFullscreen = () => {
        const v = video as HTMLVideoElement & { webkitEnterFullscreen?: () => void };
        if (typeof v.webkitEnterFullscreen === 'function') {
          // iOS Safari: standard Fullscreen API isn't supported on <video>,
          // but webkitEnterFullscreen enters the native video player.
          v.webkitEnterFullscreen();
        } else if (typeof video.requestFullscreen === 'function') {
          void video.requestFullscreen();
        }
      };
      video.addEventListener('click', onTapFullscreen);

      // Once the user has gone fullscreen at least once, they're engaged —
      // swap the tap-to-fullscreen gesture for native controls so they can
      // scrub, pause, etc. inline without having to re-open fullscreen.
      let wasFullscreen = false;
      const onExitFullscreen = () => {
        video.removeEventListener('click', onTapFullscreen);
        video.setAttribute('controls', '');
      };
      video.addEventListener('webkitbeginfullscreen', () => {
        wasFullscreen = true;
      });
      video.addEventListener('webkitendfullscreen', onExitFullscreen);
      document.addEventListener('fullscreenchange', () => {
        if (document.fullscreenElement === video) {
          wasFullscreen = true;
        } else if (wasFullscreen) {
          onExitFullscreen();
        }
      });
    }

    let ended = false;

    const tryPlay = () => {
      const attempt = video.play();
      if (attempt && typeof attempt.then === 'function') {
        attempt.catch((err: unknown) => {
          // Surface the real reason so we can diagnose iOS autoplay refusals
          // (e.g., Low Power Mode, per-site autoplay block).
          console.warn('[demo-video] autoplay blocked:', err);
        });
      }
    };

    video.addEventListener('ended', () => {
      ended = true;
      replay?.classList.remove('hidden');
      replay?.classList.add('flex');
    });

    replay?.addEventListener('click', () => {
      replay.classList.add('hidden');
      replay.classList.remove('flex');
      ended = false;
      video.currentTime = 0;
      tryPlay();
    });

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduced) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting && !ended) {
              tryPlay();
            } else if (!entry.isIntersecting) {
              video.pause();
            }
          }
        },
        { threshold: 0.5 },
      );
      io.observe(video);
    }
  }
</script>
