---
import { loadAllSections } from '../lib/content';
import { getAllDomains } from '../lib/domains';
import SidebarSearch from '../islands/SidebarSearch';
interface Props { currentSlug: string; }
const { currentSlug } = Astro.props;
const sections = loadAllSections();
const domains = getAllDomains();
const searchItems = sections.flatMap(s =>
  s.items.map(item => ({
    id: item.id,
    title: item.title,
    description: item.description,
    severity: item.severity,
    sectionSlug: s.slug,
    sectionName: s.name,
    itemSlug: item.slug,
  }))
);
const sectionsByDomain = new Map<string, typeof sections>();
for (const section of sections) {
  const group = sectionsByDomain.get(section.domain) ?? [];
  group.push(section);
  sectionsByDomain.set(section.domain, group);
}

const isIntroActive = currentSlug === '';
const isGettingStartedActive = currentSlug === 'getting-started';
---
<nav class="w-56 shrink-0 overflow-y-auto max-h-[calc(100vh-3.5rem)] sticky top-14 border-r border-gray-100">
  <div class="py-5 pl-5 pr-3">

    <!-- Search -->
    <div class="mb-4">
      <SidebarSearch client:idle items={searchItems} />
    </div>

    <!-- Top links -->
    <div class="mb-5 pb-4 border-b border-gray-100">
      <a
        href="/checklist/"
        class:list={[
          'flex items-center gap-2 px-2.5 py-1.5 text-[13px] rounded-md transition-all',
          isIntroActive
            ? 'bg-[#052e16] text-white font-semibold shadow-sm'
            : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50',
        ]}
      >
        <svg class:list={['w-3.5 h-3.5 shrink-0', isIntroActive ? 'text-[#4ade80]' : 'text-gray-300']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" />
        </svg>
        Introduction
      </a>
      <a
        href="/checklist/getting-started/"
        class:list={[
          'flex items-center gap-2 px-2.5 py-1.5 text-[13px] rounded-md transition-all mt-0.5',
          isGettingStartedActive
            ? 'bg-[#052e16] text-white font-semibold shadow-sm'
            : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50',
        ]}
      >
        <svg class:list={['w-3.5 h-3.5 shrink-0', isGettingStartedActive ? 'text-[#4ade80]' : 'text-gray-300']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        Getting Started
      </a>
      <a
        href="/checklist/commands/"
        class:list={[
          'flex items-center gap-2 px-2.5 py-1.5 text-[13px] rounded-md transition-all mt-0.5',
          currentSlug === 'commands'
            ? 'bg-[#052e16] text-white font-semibold shadow-sm'
            : 'text-gray-500 hover:text-gray-900 hover:bg-gray-50',
        ]}
      >
        <svg class:list={['w-3.5 h-3.5 shrink-0', currentSlug === 'commands' ? 'text-[#4ade80]' : 'text-gray-300']} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        Commands
      </a>
    </div>

    <!-- Domain groups -->
    {domains.map((domain, i) => {
      const group = sectionsByDomain.get(domain) ?? [];
      if (group.length === 0) return null;
      const hasActiveChild = group.some(s => s.slug === currentSlug);
      return (
        <div class:list={['mb-1', i > 0 && 'mt-4']}>
          <h3 class:list={[
            'text-[11px] font-extrabold uppercase tracking-[0.06em] mb-1.5 px-2.5 leading-tight',
            hasActiveChild ? 'text-[#052e16]' : 'text-gray-400',
          ]}>
            {domain}
          </h3>
          {group.map(s => {
            const isActive = s.slug === currentSlug;
            return (
              <a
                href={`/checklist/${s.slug}/`}
                class:list={[
                  'group flex items-center gap-2 pl-2.5 pr-2 py-[5px] text-[13px] rounded-md transition-all leading-snug',
                  isActive
                    ? 'bg-[#052e16] text-white font-semibold shadow-sm'
                    : 'text-gray-500 hover:text-gray-800 hover:bg-gray-50',
                ]}
              >
                <span class:list={[
                  'w-1 h-1 rounded-full shrink-0 transition-colors',
                  isActive ? 'bg-[#4ade80]' : 'bg-gray-200 group-hover:bg-gray-400',
                ]} />
                <span class="truncate">{s.name}</span>
              </a>
            );
          })}
        </div>
      );
    })}

  </div>
</nav>
