<section class="bg-[#edf5f0] border-y border-[#d5e5db] py-16 px-6 text-center">
  <h2 class="text-2xl font-extrabold text-[#052e16] mb-2">Stay in the loop.</h2>
  <p class="text-[#166534] mb-6">New sections, audit improvements, and the occasional CTO war story.</p>
  <form class="flex gap-2 justify-center max-w-md mx-auto" onsubmit="event.preventDefault()">
    <input
      type="email"
      placeholder="you@company.com"
      class="flex-1 px-4 py-2.5 border border-[#d5e5db] rounded-lg text-sm bg-white outline-none focus:border-[#16a34a] focus:ring-2 focus:ring-[#16a34a]/10"
    />
    <button type="submit" class="bg-[#052e16] text-[#4ade80] px-6 py-2.5 rounded-lg text-sm font-bold whitespace-nowrap hover:bg-[#0a3d1f] transition-colors">
      Subscribe
    </button>
  </form>
</section>
